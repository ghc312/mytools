#!/bin/bash
# 本地 pre-commit hook：每次 commit 前自动更新 README
# 安装方式：bash scripts/install-hooks.sh

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
UPDATE_SCRIPT="$REPO_ROOT/scripts/update-readme.py"

cd "$REPO_ROOT"

echo "🔍 检测工具目录变化，自动更新 README..."

if [ -f "$UPDATE_SCRIPT" ]; then
    python3 "$UPDATE_SCRIPT"
else
    echo "⚠️  找不到 $UPDATE_SCRIPT，跳过"
    exit 0
fi

# 把更新后的 README 加入暂存区
git add README.md
echo "✅ README 已更新"
